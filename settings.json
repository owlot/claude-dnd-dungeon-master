{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "PROJECT_ROOT": "."
  },
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Bash(mkdir -p website/*)",
      "Bash(set -a && source .env && set +a && uv run python*)",
      "Bash(python .claude/tools/*)",
      "Bash(python3 .claude/tools/*)",
      "Bash(node .claude/tools/*)",
      "Bash(python .claude/scripts/*)",
      "Bash(${TTS_PYTHON} tools/*)",
      "Bash(${TTS_PYTHON} .claude/tools/*)",
      "Bash(python tools/*)",
      "Bash(python3 tools/*)",
      "Bash(paplay *)",
      "Bash(ls campaigns/*)",
      "Bash(ls website/*)",
      "Bash(./.claude/tools/*)",
      "Write(website/**)",
      "Write(campaigns/*/info/**)",
      "Write(campaigns/*/party/**)"
    ]
  }
}
